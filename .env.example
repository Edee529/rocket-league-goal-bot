# Discord Bot Token — get this from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_bot_token_here

# Discord Channel ID — where goal notifications are posted
DISCORD_CHANNEL_ID=your_channel_id_here

# Discord Server ID — for instant command registration (right-click server → Copy ID)
GUILD_ID=your_guild_id_here

# Player names to track (comma-separated)
TRACKED_PLAYERS=Player01,Player02

# Leader Channel ID — auto-updates with leader (right-click channel → Copy ID)
# Bot needs "Manage Channels" permission in this channel
LEADER_CHANNEL_ID=your_channel_id_here

# Rocket League Stats API port
RL_PORT=49123
